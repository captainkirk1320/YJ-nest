# YJ-Nest engine credentials template
# Copy to .env and fill in real values. .env is gitignored.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

DATABASE_URL_DIRECT=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_POOLER=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
